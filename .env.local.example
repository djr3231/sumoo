# Google AI (Gemini)
# Get from: https://aistudio.google.com/apikey
GOOGLE_AI_KEY=AIza...

# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...

# NextAuth
NEXTAUTH_SECRET=run "openssl rand -base64 32" and paste here
NEXTAUTH_URL=http://localhost:3000

# Last 4 digits of YOUR personal credit card.
# Receipts paid with this card → "אשראי". Other cards or cash → "מזומן".
MY_CREDIT_CARD_LAST4=6021

# Optional: pin to a specific spreadsheet. If empty, the app creates one on first login.
SUMOO_SPREADSHEET_ID=
